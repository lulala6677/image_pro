# ===========================================
# 图像处理平台 - 环境变量配置
# ===========================================
# 使用前请复制此文件为 .env 并填入你的配置

# ===========================================
# 数据库配置 (Supabase)
# ===========================================
# 从 Supabase 项目设置 -> API 中获取
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ===========================================
# 对象存储配置 (AWS S3 兼容)
# ===========================================
# 推荐使用 Cloudflare R2 (免费10GB/月) 或 AWS S3
# Cloudflare R2 配置示例:
S3_ENDPOINT=https://your-account.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=your-bucket-name
S3_PUBLIC_URL=https://pub.your-domain.workers.dev  # 公开访问地址

# 或使用阿里云 OSS:
# S3_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# S3_REGION=oss-cn-hangzhou
# S3_ACCESS_KEY_ID=your-access-key
# S3_SECRET_ACCESS_KEY=your-secret-key
# S3_BUCKET_NAME=your-bucket-name
# S3_PUBLIC_URL=https://your-bucket.oss-cn-hangzhou.aliyuncs.com

# ===========================================
# AI 图像生成配置 (OpenAI 兼容)
# ===========================================
# 支持 OpenAI DALL-E、阿里云通义万相等
OPENAI_API_KEY=your-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=dall-e-3

# 或使用阿里云通义万相:
# OPENAI_API_KEY=your-dashscope-api-key
# OPENAI_API_BASE=https://dashscope.aliyuncs.com/api/v1
# OPENAI_MODEL=dall-e-3

# ===========================================
# 应用配置
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:5000
