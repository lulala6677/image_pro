# ============================================
# 数字图像处理实验室 - 环境变量配置
# ============================================
# 请复制此文件为 .env 并填写实际值
# cp .env.example .env
# ============================================

# ============================================
# Supabase 数据库
# 注册地址: https://supabase.com
# 免费额度: 500MB 数据库
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# 阿里云 OSS 对象存储（国内推荐，速度快）
# 注册地址: https://www.aliyun.com/product/oss
# 免费额度: 40GB 存储
# ============================================
# Region: oss-cn-beijing（北京）, oss-cn-shanghai（上海）, oss-cn-hangzhou（杭州）, oss-cn-guangzhou（广州）等
OSS_REGION=oss-cn-beijing
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET=oss-pai-qzf3opy47dy5sz1ehd-cn-hangzhou
# CDN 加速域名（可选，配置后访问更快）
# OSS_CDN_URL=https://your-cdn-domain.com

# ============================================
# OpenAI AI 图像生成（可选）
# 注册地址: https://platform.openai.com
# 免费额度: $5 试用额度
# ============================================
OPENAI_API_KEY=sk-your-api-key
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=dall-e-3

# ============================================
# 阿里云通义万相（国内替代方案，可选）
# 注册地址: https://dashscope.console.aliyun.com
# ============================================
# 如果使用通义万相，取消下面注释并填写
# OPENAI_API_KEY=your-dashscope-api-key
# OPENAI_API_BASE=https://dashscope.aliyuncs.com/api/v1
